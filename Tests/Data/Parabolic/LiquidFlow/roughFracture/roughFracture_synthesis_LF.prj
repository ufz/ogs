<?xml version="1.0" encoding="ISO-8859-1"?>
<OpenGeoSysProject>
    <meshes>
      <mesh>joint_sigma_20MPa_midplane_tri.vtu</mesh>
      <mesh>left.vtu</mesh>
      <mesh>right.vtu</mesh>
      <mesh>bottom.vtu</mesh>
      <mesh>top.vtu</mesh>
    </meshes>
    <processes>
        <process>
            <name>LiquidFlow</name>
            <type>LIQUID_FLOW</type>
            <integration_order>2</integration_order>
            <process_variables>
                <process_variable>pressure</process_variable>
            </process_variables>
            <secondary_variables>
                <secondary_variable internal_name="darcy_velocity" output_name="v"/>
            </secondary_variables>
            <equation_balance_type>mass</equation_balance_type>
            <specific_body_force>0.0 0.0 -9.8</specific_body_force>
            <aperture_size>
                <parameter>fracture_thickness_const</parameter>
            </aperture_size>
        </process>
    </processes>
    <media>
        <medium id="0">
            <phases>
                <phase>
                    <type>AqueousLiquid</type>
                    <properties>
                        <property>
                            <name>viscosity</name>
                            <type>Constant</type>
                            <value> 1.e-3 </value>
                        </property>
                        <property>
                            <name>density</name>
                            <type>Linear</type>
                            <reference_value>1000</reference_value>
                            <independent_variable>
                                <variable_name>liquid_phase_pressure</variable_name>
                                <reference_condition>1e5</reference_condition>
                                <slope>4.5e-7</slope>
                            </independent_variable>
                        </property>
                    </properties>
                </phase>
            </phases>
            <properties>
                <property>
                    <name>permeability</name>
                    <type>Parameter</type>
                    <parameter_name>kappa1_frac</parameter_name>
                </property>
                <property>
                    <name>reference_temperature</name>
                    <type>Constant</type>
                    <value>293.15</value>
                </property>
                <property>
                    <name>porosity</name>
                    <type>Parameter</type>
                    <parameter_name>constant_porosity_parameter</parameter_name>
                </property>
                <property>
                    <name>storage</name>
                    <type>Constant</type>
                    <value> 0.0 </value>
                </property>
            </properties>
        </medium>
    </media>
    <time_loop>
        <processes>
            <process ref="LiquidFlow">
                        <nonlinear_solver>basic_picard</nonlinear_solver>
                        <convergence_criterion>
                            <type>PerComponentDeltaX</type>
                            <norm_type>NORM2</norm_type>
                            <reltols>1e-10</reltols>
                        </convergence_criterion>
                        <time_discretization>
                            <type>BackwardEuler</type>
                        </time_discretization>
                        <time_stepping>
                            <type>IterationNumberBasedTimeStepping</type>
                            <t_initial>0.0</t_initial>
                            <t_end>10</t_end>
                            <initial_dt>1e-2</initial_dt>
                            <minimum_dt>1.e-6</minimum_dt>
                            <maximum_dt>1.0</maximum_dt>
                            <number_iterations>1  7  11 15</number_iterations>
                            <multiplier> 1.4 1.2 0.9 0.5</multiplier>
                        </time_stepping>
            </process>
        </processes>
        <output>
            <type>VTK</type>
            <prefix>fracture_block_conduct</prefix>
            <timesteps>
                <pair>
                    <repeat> 1 </repeat>
                    <each_steps> 1 </each_steps>
                </pair>
            </timesteps>
            <variables>
            </variables>
            <suffix>_ts_{:timestep}_t_{:time}</suffix>
        </output>
    </time_loop>
    <parameters>
        <parameter>
            <name>constant_porosity_parameter</name>
            <type>Constant</type>
            <value>0.005</value>
        </parameter>
        <parameter>
            <name>p0</name>
            <type>Constant</type>
            <value>100000</value>
        </parameter>
        <parameter>
            <name>p_left</name>
            <type>Constant</type>
            <value>500000</value>
        </parameter>
        <parameter>
            <name>p_right</name>
            <type>Constant</type>
            <value>100000</value>
        </parameter>
        <parameter>
            <name>q_left</name>
            <type>Constant</type>
            <value>3e-6</value>
        </parameter>
        <parameter>
            <name>kappa1_frac</name>
            <type>MeshElement</type>
            <field_name>permeability_cubic</field_name>
        </parameter>
        <parameter>
            <name>fracture_thickness_const</name>
            <type>MeshElement</type>
            <field_name>aperture_closed</field_name>
        </parameter>
    </parameters>
    <process_variables>
        <process_variable>
            <name>pressure</name>
            <components>1</components>
            <order>1</order>
            <initial_condition>p0</initial_condition>
            <boundary_conditions>
                <boundary_condition>
                    <type>Dirichlet</type>
                    <mesh>right</mesh>
                    <parameter>p_right</parameter>
                </boundary_condition>
                <boundary_condition>
                    <type>Dirichlet</type>
                    <mesh>left</mesh>
                    <parameter>p_left</parameter>
                </boundary_condition>
            </boundary_conditions>
        </process_variable>
    </process_variables>
    <nonlinear_solvers>
        <nonlinear_solver>
            <name>basic_picard</name>
            <type>Picard</type>
            <max_iter>100</max_iter>
            <linear_solver>general_linear_solver</linear_solver>
        </nonlinear_solver>
    </nonlinear_solvers>
    <linear_solvers>
        <linear_solver>
            <name>general_linear_solver</name>
            <eigen>
                <solver_type>SparseLU</solver_type>
                <scaling>true</scaling>
            </eigen>
        </linear_solver>
    </linear_solvers>
</OpenGeoSysProject>
